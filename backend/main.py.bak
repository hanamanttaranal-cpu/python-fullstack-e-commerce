def seed_products_if_empty():
    try:
        conn = get_connection()
        with conn.cursor() as cursor:
            cursor.execute("SELECT COUNT(*) as count FROM products")
            result = cursor.fetchone()
            count = result['count'] if result else 0
            if count == 0:
                logger.info("Products table is empty. Seeding standard products into MySQL...")
                for p in SEED_PRODUCTS:
                    cursor.execute("""
                        INSERT INTO products (name, price, description, image, category, stock, rating, featured)
                        VALUES (%s, %s, %s, %s, %s, %s, %s, %s)
                    """, (
                        p["name"], p["price"], p["description"], p["image"],
                        p["category"], p["stock"], p["rating"], 1 if p["featured"] else 0
                    ))
                conn.commit()
                logger.info("MySQL catalog seeding completed successfully!")
            else:
                logger.info(f"MySQL already has {count} products. Skipping seeding.")
        conn.close()
    except Exception as e:
        logger.error(f"Failed to seed products: {e}")

# API Routes
@app.get("/")
async def root():
    return {
        "status": "online",
        "service": "AuraMarket Python API Backend",
        "framework": "FastAPI",
        "database": "MySQL"
    }

@app.get("/api/products", response_model=List[ProductResponse])
async def get_products(category: Optional[str] = None):
    try:
        conn = get_connection()
        with conn.cursor() as cursor:
            if category:
                cursor.execute("SELECT * FROM products WHERE category = %s", (category,))
            else:
                cursor.execute("SELECT * FROM products")
            rows = cursor.fetchall()
        conn.close()
        
        products = []
        for row in rows:
            products.append({
                "id": str(row["id"]),
                "name": row["name"],
                "price": float(row["price"]),
                "description": row["description"],
                "image": row["image"],
                "category": row["category"],
                "stock": row["stock"],
                "rating": float(row["rating"]) if row["rating"] is not None else 4.5,
                "featured": bool(row["featured"])
            })
        return products
    except Exception as e:
        logger.error(f"Error fetching products: {e}")
        raise HTTPException(status_code=500, detail="Database error")

@app.get("/api/products/{product_id}", response_model=ProductResponse)
async def get_product(product_id: str):
    try:
        conn = get_connection()
        with conn.cursor() as cursor:
            cursor.execute("SELECT * FROM products WHERE id = %s", (product_id,))
            row = cursor.fetchone()
        conn.close()
        if not row:
            raise HTTPException(status_code=404, detail="Product not found")
        return {
            "id": str(row["id"]),
            "name": row["name"],
            "price": float(row["price"]),
            "description": row["description"],
            "image": row["image"],
            "category": row["category"],
            "stock": row["stock"],
            "rating": float(row["rating"]) if row["rating"] is not None else 4.5,
            "featured": bool(row["featured"])
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error fetching product: {e}")
        raise HTTPException(status_code=500, detail="Database error")

@app.post("/api/products", response_model=ProductResponse, status_code=status.HTTP_201_CREATED)
async def create_product(product: ProductSchema):
    try:
        conn = get_connection()
        with conn.cursor() as cursor:
            cursor.execute("""
                INSERT INTO products (name, price, description, image, category, stock, rating, featured)
                VALUES (%s, %s, %s, %s, %s, %s, %s, %s)
            """, (
                product.name, product.price, product.description, product.image,
                product.category, product.stock, product.rating, 1 if product.featured else 0
            ))
            product_id = cursor.lastrowid
        conn.commit()
        conn.close()
        
        return {
            "id": str(product_id),
            "name": product.name,
            "price": product.price,
            "description": product.description,
            "image": product.image,
            "category": product.category,
            "stock": product.stock,
            "rating": product.rating,
            "featured": product.featured
        }
    except Exception as e:
        logger.error(f"Error creating product: {e}")
        raise HTTPException(status_code=500, detail="Database error")

@app.get("/api/orders", response_model=List[OrderResponse])
async def get_orders(email: Optional[str] = None):
    try:
        conn = get_connection()
        with conn.cursor() as cursor:
            if email:
                cursor.execute("SELECT * FROM orders WHERE customerEmail = %s ORDER BY createdAt DESC", (email,))
            else:
                cursor.execute("SELECT * FROM orders ORDER BY createdAt DESC")
            orders_rows = cursor.fetchall()
            
            orders = []
            for order_row in orders_rows:
                cursor.execute("SELECT * FROM order_items WHERE orderId = %s", (order_row["id"],))
                items_rows = cursor.fetchall()
                
                items = [{
                    "productId": row["productId"],
                    "name": row["name"],
                    "price": float(row["price"]),
                    "quantity": row["quantity"],
                    "image": row["image"]
                } for row in items_rows]
                
                orders.append({
                    "id": str(order_row["id"]),
                    "customerName": order_row["customerName"],
                    "customerEmail": order_row["customerEmail"],
                    "shippingAddress": order_row["shippingAddress"],
                    "totalAmount": float(order_row["totalAmount"]),
                    "status": order_row["status"],
                    "items": items
                })
        conn.close()
        return orders
    except Exception as e:
        logger.error(f"Error fetching orders: {e}")
        raise HTTPException(status_code=500, detail="Database error")

@app.post("/api/orders", response_model=OrderResponse, status_code=status.HTTP_201_CREATED)
async def create_order(order: OrderSchema):
    try:
        conn = get_connection()
        with conn.cursor() as cursor:
            # 1. Insert order
            cursor.execute("""
                INSERT INTO orders (customerName, customerEmail, shippingAddress, totalAmount, status)
                VALUES (%s, %s, %s, %s, %s)
            """, (
                order.customerName, order.customerEmail, order.shippingAddress,
                order.totalAmount, order.status or "Pending"
            ))
            order_id = cursor.lastrowid
            
            # 2. Insert order items & adjust stock
            for item in order.items:
                cursor.execute("""
                    INSERT INTO order_items (orderId, productId, name, price, quantity, image)
                    VALUES (%s, %s, %s, %s, %s, %s)
                """, (
                    order_id, item.productId, item.name, item.price, item.quantity, item.image
                ))
                
                # Try to adjust stock (assuming productId is an int string)
                try:
                    product_db_id = int(item.productId)
                    cursor.execute("SELECT stock FROM products WHERE id = %s", (product_db_id,))
                    prod = cursor.fetchone()
                    if prod:
                        new_stock = max(0, prod["stock"] - item.quantity)
                        cursor.execute("UPDATE products SET stock = %s WHERE id = %s", (new_stock, product_db_id))
                except ValueError:
                    # In case of non-integer productId formats
                    pass
                    
        conn.commit()
        conn.close()
        
        return {
            "id": str(order_id),
            "customerName": order.customerName,
            "customerEmail": order.customerEmail,
            "shippingAddress": order.shippingAddress,
            "items": [item.dict() for item in order.items],
            "totalAmount": order.totalAmount,
            "status": order.status or "Pending"
        }
    except Exception as e:
        logger.error(f"Error creating order: {e}")
        raise HTTPException(status_code=500, detail="Database error")
