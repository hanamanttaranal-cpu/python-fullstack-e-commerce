rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Safety Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Safely retrieves the incoming document map
    function incoming() {
      return request.resource.data;
    }

    // Safely retrieves the existing document map
    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 3. Admin lookup helper
    // Bootstrapped with user email 'hanamanttaranal19@gmail.com' and the admins collection
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'hanamanttaranal19@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 4. Entity Validation Blueprints

    // User profile validation
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'photoURL', 'email', 'createdAt'])
        && data.keys().size() == 4
        && data.displayName is string && data.displayName.size() <= 100
        && data.photoURL is string && data.photoURL.size() <= 500
        && data.email is string && data.email.size() <= 100 && data.email == request.auth.token.email
        && data.createdAt == request.time;
    }

    // Product validation
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'category', 'image', 'rating', 'reviewCount', 'stock', 'featured'])
        && data.keys().size() == 9
        && data.name is string && data.name.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() <= 50
        && data.image is string && data.image.size() <= 500
        && data.rating is number && data.rating >= 0 && data.rating <= 5
        && data.reviewCount is int && data.reviewCount >= 0
        && data.stock is int && data.stock >= 0
        && data.featured is bool;
    }

    // Cart validation
    function isValidCart(data, userId) {
      return data.keys().hasAll(['userId', 'items', 'updatedAt'])
        && data.keys().size() == 3
        && data.userId == userId
        && data.userId == request.auth.uid
        && data.items is list
        && data.items.size() <= 100
        && data.updatedAt == request.time;
    }

    // Order validation
    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'shippingAddress', 'paymentMethod', 'subtotal', 'tax', 'shipping', 'total', 'status', 'createdAt'])
        && data.keys().size() == 10
        && data.userId == request.auth.uid
        && data.items is list
        && data.items.size() > 0 && data.items.size() <= 100
        && data.shippingAddress is map
        && data.paymentMethod is string && data.paymentMethod.size() <= 50
        && data.subtotal is number && data.subtotal >= 0
        && data.tax is number && data.tax >= 0
        && data.shipping is number && data.shipping >= 0
        && data.total is number && data.total >= 0
        && data.status == 'Pending'
        && data.createdAt == request.time;
    }

    // Review validation
    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt'])
        && data.keys().size() == 6
        && data.productId is string && data.productId.size() <= 100
        && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && data.createdAt == request.time;
    }

    // 5. Collection Rules

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isVerifiedUser() && isValidId(userId) && isOwner(userId) && isValidUser(incoming());
      allow update: if isVerifiedUser() && isValidId(userId) && isOwner(userId) && isValidUser(incoming())
                       && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Carts
    match /carts/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isVerifiedUser() && isValidId(userId) && isOwner(userId) && isValidCart(incoming(), userId);
      allow update: if isVerifiedUser() && isValidId(userId) && isOwner(userId) && isValidCart(incoming(), userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow list: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow get: if isVerifiedUser() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerifiedUser() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isAdmin() && isValidId(orderId);
      allow delete: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read, list: if true;
      allow create: if isVerifiedUser() && isValidId(reviewId) && isValidReview(incoming());
      allow update: if isVerifiedUser() && isValidId(reviewId) && existing().userId == request.auth.uid && isValidReview(incoming())
                       && incoming().productId == existing().productId
                       && incoming().userId == existing().userId;
      allow delete: if isVerifiedUser() && (existing().userId == request.auth.uid || isAdmin());
    }

    // Admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
